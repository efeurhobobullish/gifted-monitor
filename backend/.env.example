PORT=58420

# Database — auto-detects type from URL prefix (postgresql://, mongodb://, mysql://) so one can use any of the three
DATABASE_URL=

# WhatsApp Business API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# Telegram Bot (optional — get token from @BotFather; users link chat id in app)
TELEGRAM_BOT_TOKEN=

# WhatsApp Template Names (fill after creating in Meta Business)
WA_TEMPLATE_OTP=gifted_monitor_otp
WA_TEMPLATE_MONITOR_CREATED=gifted_monitor_created
WA_TEMPLATE_SITE_DOWN=gifted_monitor_down
WA_TEMPLATE_SITE_RECOVERED=gifted_monitor_back_online

# Email (required for signup/OTP codes — Gmail App Password)
EMAIL=
EMAIL_APP_PASSWORD=
# Legacy alias for app password (optional; EMAIL_APP_PASSWORD is preferred)
# PASSWORD=
EMAIL_APP_URL=https://monitor.giftedtech.co.ke
EMAIL_FROM_NAME=Gifted Monitor
EMAIL_LOGO_URL=

# App
JWT_SECRET=
PING_CHECK_INTERVAL_SECS=10
MIN_PING_INTERVAL_MINS=1

# Add more, Comma separated
ALLOWED_ORIGINS=https://monitor.giftedtech.co.ke,https://anotherapp.co.ke
